---
import { getEntry } from 'astro:content';
import CloudinaryImage from './CloudinaryImage.astro';
import Date from './Date.astro';

interface Props {
  id: string;
}

const { id } = Astro.props;

const post = await getEntry('blog', id);
if (!post) {
  throw new Error(`Blog post with id "${id}" not found`);
}
---

{post && (
  <a href={`/blog/${id}/`} class="group flex flex-col rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 shadow-sm hover:shadow-md transition-shadow duration-200 no-underline">
    {post.data.heroImage ? (
      <div class="h-32 overflow-hidden bg-zinc-100 dark:bg-zinc-900">
        <CloudinaryImage
          publicId={post.data.heroImage}
          alt={post.data.title}
          width={400}
          height={128}
          gravity="north"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="h-32 bg-zinc-100 dark:bg-zinc-900 flex items-center justify-center">
        <span class="text-zinc-400 dark:text-zinc-600 text-4xl font-bold">#</span>
      </div>
    )}
    <div class="p-4 flex flex-col flex-1">
      <p class="font-semibold text-sm text-zinc-800 dark:text-zinc-100 leading-snug mb-2 group-hover:text-teal-500 dark:group-hover:text-teal-400 transition-colors">
        {post.data.title}
      </p>
      <div class="mt-auto text-xs text-zinc-500 dark:text-zinc-400 not-prose">
        <Date date={post.data.date} />
      </div>
    </div>
  </a>
)}
