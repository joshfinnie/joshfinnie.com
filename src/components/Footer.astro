---
import { footerNavLinks } from '../config/nav';
import CloudinaryImage from './CloudinaryImage.astro';

const year = new Date().getFullYear();
---

<footer class="mt-32 flex-none">
  <div class="sm:px-8">
    <div class="mx-auto w-full max-w-7xl lg:px-8">
      <div class="border-t border-zinc-100 pb-16 pt-10 dark:border-zinc-700/40">
        <div class="relative px-4 sm:px-8 lg:px-12">
          <div class="mx-auto max-w-2xl lg:max-w-5xl">
            <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
              <div
                class="flex flex-wrap justify-center gap-x-6 gap-y-1 text-sm font-medium text-zinc-800 dark:text-zinc-200"
              >
                {
                  footerNavLinks.map((link) => (
                    <Fragment key={link.label}>
                      <a class="transition hover:text-teal-500 dark:hover:text-teal-400" href={link.href}>
                        {link.label}
                      </a>
                    </Fragment>
                  ))
                }
              </div>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">
                &copy; 2010 - <!-- -->{year}<!-- --> Josh Finnie.
                <CloudinaryImage
                  publicId="icons/by-nc-sa"
                  alt="creative commons license"
                  class="inline ml-5"
                  width={88}
                  height={31}
                />
              </p>
            </div>
            <p class="mt-6 text-center text-sm text-zinc-600 dark:text-zinc-400">
              Built with <a href="https://astro.build" class="text-teal-500 dark:text-teal-400 transition hover:text-teal-600 dark:hover:text-teal-300">Astro</a>. Source code on <a href="https://github.com/joshfinnie/joshfinnie.com" class="text-teal-500 dark:text-teal-400 transition hover:text-teal-600 dark:hover:text-teal-300">GitHub</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
