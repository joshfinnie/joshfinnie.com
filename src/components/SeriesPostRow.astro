---
import type { CollectionEntry } from 'astro:content';
import { format, parseISO } from 'date-fns';

interface Props {
  post: CollectionEntry<'blog'>;
  partNumber: number;
}

const { post, partNumber } = Astro.props;
const formattedDate = format(parseISO(post.data.date), 'LLLL d, yyyy');
---

<li class="py-4">
  <a href={`/blog/${post.id}/`} class="group flex items-start gap-4 no-underline">
    <span class="shrink-0 mt-0.5 inline-block w-16 text-center text-xs font-semibold uppercase tracking-wide rounded-full px-2 py-1 bg-zinc-200 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-300">
      Part {partNumber}
    </span>
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4">
        <span class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:underline leading-snug">
          {post.data.title}
        </span>
        <span class="shrink-0 text-sm text-zinc-500 dark:text-zinc-400 whitespace-nowrap">
          {formattedDate}
        </span>
      </div>
      {post.data.description && (
        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400 leading-snug">
          {post.data.description}
        </p>
      )}
    </div>
  </a>
</li>
